# App URLs
APP_PUBLIC_URL=https://app.example.com
API_PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://app.example.com

# Images (updated by CI/CD deploy scripts)
BACKEND_IMAGE=ghcr.io/your-org/sandaga-backend:latest
FRONTEND_IMAGE=ghcr.io/your-org/sandaga-frontend:latest

# Ports on VPS host
BACKEND_PORT=3000
FRONTEND_PORT=80
PORT=3000

# Database
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=change_me_strong_password
DATABASE_NAME=sandaga
DATABASE_SYNCHRONIZE=false

# Auth
JWT_SECRET=change_me_super_long_random_secret
JWT_EXPIRES_IN=3600

# Storage (MinIO local on VPS)
STORAGE_DRIVER=s3
STORAGE_S3_BUCKET=sandaga-media
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY_ID=minioadmin
STORAGE_S3_SECRET_ACCESS_KEY=minioadmin
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_PUBLIC_URL=https://media.example.com/sandaga-media
STORAGE_S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Payments
ZIKOPAY_MOCK_MODE=false
ZIKOPAY_API_KEY=
ZIKOPAY_API_SECRET=
ZIKOPAY_BASE_URL=

# Messaging / emails (optional but recommended)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@example.com

# AI autoresponse (optional)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_AUTOREPLY_ENABLED=true

DELIVERY_COMMISSION_RATE=0.05
PLATFORM_WALLET_USER_ID=
